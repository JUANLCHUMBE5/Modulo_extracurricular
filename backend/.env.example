# Modos de datos:
# local      = VS Code + server/db.json
# production = Vercel/servidor + API oficial del colegio
DATA_MODE=local
VITE_DATA_MODE=local

# Modo de la API del Frontend:
# mock = usar base de datos simulada en memoria y localStorage/JSON server (por defecto)
# api  = consumir endpoints REST reales mediante VITE_API_URL
VITE_API_MODE=mock

# Produccion futura: API oficial del colegio.
# El token o api key se guardan solo en el backend, nunca en variables VITE_.
OFFICIAL_API_BASE_URL=
OFFICIAL_API_DB_PATH=/api/modulo-extracurricular
OFFICIAL_API_RESET_PATH=
OFFICIAL_API_TOKEN=
OFFICIAL_API_KEY=

# Local: deja VITE_API_URL vacio y Vite usa VITE_LOCAL_API_URL/proxy.
# Vercel mismo proyecto: puedes dejar VITE_API_URL vacio y usara /api/db.
# Nube separada: VITE_API_URL debe ser la URL publica de tu backend Node, sin / al final.
VITE_API_URL=
VITE_LOCAL_API_URL=http://127.0.0.1:5175

# Backend en nube.
PORT=
API_HOST=0.0.0.0
FRONTEND_URL=https://tu-frontend-publico.com
ALLOWED_ORIGINS=

# Firma de JWT
JWT_SECRET=cambiar-por-secreto-seguro-en-produccion

# Supabase Credentials (requerido si DATA_MODE es 'supabase')
SUPABASE_URL=
SUPABASE_KEY=

# Servidor de Correo SMTP (Notificaciones de Matrícula)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contrasena_de_aplicacion
SMTP_SENDER_NAME=Modulo Extracurricular


