@startuml
title FLUJO GENERAL DEL SISTEMA - MÓDULO EXTRACURRICULAR

skinparam defaultFontName "Segoe UI", Arial, sans-serif
skinparam defaultFontSize 12
skinparam shadowing false
skinparam roundcorner 10
skinparam backgroundColor #FFFFFF

' Swimlane Styling
skinparam swimlane {
  BorderColor #E2ECE9
  BorderThickness 1.5
  TitleFontColor #176C60
  TitleFontSize 13
  TitleFontBold true
}

' Activity Node Styling
skinparam activity {
  BackgroundColor #FFFFFF
  BorderColor #176C60
  BorderThickness 1.5
  FontColor #1A2332
  FontSize 12
  
  ' Start/Stop Nodes
  StartColor #176C60
  EndColor #B42318
}

' Diamond (Decision) Styling
skinparam ActivityDiamond {
  BackgroundColor #EAF8F3
  BorderColor #176C60
  FontColor #0F5E51
  FontSize 11
  FontBold true
}

' Arrow Styling
skinparam Arrow {
  Color #176C60
  FontColor #2E453E
  FontSize 11
  Thickness 1.3
}

|#EAF8F3|COORDINACIÓN ACADÉMICA|
start
:Crear y configurar programas/talleres;
note right: Define vacantes, costos, \nhorarios y docentes.
:Publicar programas y talleres en el sistema;

|#FFFDF5|ASISTENTE (Secretaría)|
:Recibir solicitud del estudiante;
:Buscar alumno por DNI y validar requisitos;
:Registrar preinscripción del alumno en el taller;
:Hacer clic en "Derivar a Cajera";
note right: Cambia estado de la \ninscripción en base de datos.
:Entregar ficha de preinscripción (física o digital);

|#F9F9FB|PROCESO DE COBRO|
if (¿Qué modalidad de pago utiliza el apoderado?) then (Pago Presencial)
  
  |#F0F7FF|CAJA (Cajera)|
  :Ingresar DNI y buscar preinscripción derivada;
  :Cobrar monto del taller (Efectivo o POS);
  :Clic en "Registrar Pago" (Matrícula confirmada);

else (Pago Web / Digital)

  |#FFF9E6|PADRE DE FAMILIA|
  :Ingresar al Portal Web de Padres;
  :Realizar transferencia o Yapeo;
  :Subir captura del comprobante al sistema;

  |#F0F7FF|CAJA (Cajera)|
  :Revisar comprobante de pago en el panel de Caja;
  if (¿El comprobante es válido y coincide?) then (Sí - Aprobar)
    :Aprobar Pago Web en el sistema;
  else (No - Observar o Rechazar)
    if (¿Se puede corregir?) then (Sí)
      :Marcar como "Observado" con motivo;
      |#FFF9E6|PADRE DE FAMILIA|
      :Recibe alerta y vuelve a subir comprobante;
      detach
    else (No)
      |#F0F7FF|CAJA (Cajera)|
      :Marcar como "Rechazado" (Libera vacante);
      stop
    endif
  endif

endif

|#F8F9FA|SISTEMA (Matrícula Activa)|
:Generar Constancia de Matrícula y Código QR;

|#EAF8E8|AUXILIAR (Control de Puerta)|
:Escanear el código QR del estudiante al ingresar;
if (¿La matrícula está activa y pagada?) then (Sí)
  :Permitir acceso al taller;
  :Registrar asistencia en el sistema;
else (No)
  :Denegar acceso al taller (Mostrar alerta en pantalla);
endif

stop
@enduml
