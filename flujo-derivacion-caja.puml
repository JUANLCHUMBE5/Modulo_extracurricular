@startuml
title FLUJO DE DERIVACIÓN Y COBRO (ASISTENTE A CAJA)

skinparam defaultFontName Arial
skinparam shadowing false
skinparam roundcorner 12
skinparam backgroundColor #FFFFFF
skinparam ArrowColor #333333
skinparam ArrowThickness 1.3

skinparam activity {
  BackgroundColor #F0F4F8
  BorderColor #1F6B55
  FontColor #172331
}

|#EAF6F2|ASISTENTE (Secretaría)|
start
:Ingresar DNI del estudiante;
:Seleccionar programa o taller a inscribir;
:Registrar preinscripción (Pendiente de Pago);
:Hacer clic en "Derivar a Cajera" en el sistema;
note right: Cambia el estado a\n"Derivado a Cajera"
:Entregar Ficha de Inscripción física o digital al Padre;

|#F0F7FF|CAJA (Cajera)|
:Recibe indicación del Padre o Ficha de Inscripción;
:Ingresa DNI del estudiante para buscar la inscripción derivada;
:Visualiza datos cargados automáticamente (Alumno, Taller, Costo);

if (¿Qué tipo de pago se procesará?) then (Pago Presencial)
  :Cobra el monto en ventanilla (Efectivo o POS);
  :Hace clic en "Registrar Pago" para confirmar;
  :El sistema marca la matrícula como pagada y validada;
else (Validación de Pago Web)
  :Revisa comprobante de pago subido por el Padre (Yape/Transferencia);
  if (¿El comprobante coincide y es válido?) then (Sí)
    :Hace clic en "Aprobar Pago" para validar matrícula;
  else (No / Incompleto)
    if (¿Es corregible?) then (Sí - Observar)
      :Hace clic en "Observar Pago" e ingresa el motivo;
      note right: El Padre recibirá la alerta\npara volver a subirlo
    else (No - Rechazar)
      :Hace clic en "Rechazar Pago" e ingresa el motivo;
      note right: Cancela el registro\ny libera la vacante
    endif
  endif
endif

stop
@enduml
